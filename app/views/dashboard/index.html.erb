<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-100 font-[Poppins]">

  <nav class="flex justify-between items-center px-10 py-6">

    <h1 class="text-2xl font-semibold">
      💰 Pocket Control
    </h1>

    <%= link_to "Sair", logout_path, method: :delete, class:"text-red-500 hover:text-red-600" %>

  </nav>


  <div class="max-w-6xl mx-auto px-6 mt-10">


    <div class="flex justify-between items-center mb-10">

      <h2 class="text-3xl font-bold">
        Seu Dashboard
      </h2>

      <button onclick="openModal()"
              class="bg-green-500 text-white px-5 py-2 rounded-lg hover:bg-green-600 shadow">
        Nova Transação
      </button>

    </div>



    <!-- CARDS -->

    <div class="grid md:grid-cols-3 gap-6 mb-12">

      <div class="bg-white p-6 rounded-xl shadow">

        <h3 class="text-gray-500 text-sm">
          Saldo Total
        </h3>

        <p class="text-3xl font-bold text-green-500">
          R$ <%= @saldo %>
        </p>

      </div>


      <div class="bg-white p-6 rounded-xl shadow">

        <h3 class="text-gray-500 text-sm">
          Receitas
        </h3>

        <p class="text-3xl font-bold text-blue-500">
          R$ <%= @receitas %>
        </p>

      </div>


      <div class="bg-white p-6 rounded-xl shadow">

        <h3 class="text-gray-500 text-sm">
          Despesas
        </h3>

        <p class="text-3xl font-bold text-red-500">
          R$ <%= @despesas %>
        </p>

      </div>

    </div>



    <!-- GRÁFICOS -->

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">


      <div class="bg-white rounded-xl shadow p-8">

        <h3 class="text-xl font-semibold mb-6">
          Fluxo Financeiro
        </h3>

        <div class="h-[320px]">
          <canvas id="financeChart"></canvas>
        </div>

      </div>


      <div class="bg-white rounded-xl shadow p-8">

        <h3 class="text-xl font-semibold mb-6">
          Distribuição por Categoria
        </h3>

        <div class="h-[320px]">
          <canvas id="categoryChart"></canvas>
        </div>

      </div>

    </div>



    <!-- TABELA -->

    <div class="bg-white rounded-xl shadow p-8">

      <h3 class="text-xl font-semibold mb-6">
        Transações
      </h3>

      <table class="w-full">

        <thead>

        <tr class="text-left text-gray-500 border-b">

          <th class="py-3">Descrição</th>
          <th>Categoria</th>
          <th>Valor</th>
          <th>Ações</th>

        </tr>

        </thead>

        <tbody>

        <% @transactions.order(created_at: :desc).each do |t| %>

          <tr class="border-b hover:bg-gray-50">

            <td class="py-3"><%= t.description %></td>

            <td><%= t.category %></td>

            <td class="<%= t.category == 'Receita' ? 'text-green-500' : 'text-red-500' %> font-semibold">

              <%= t.category == "Receita" ? "+" : "-" %>
              R$ <%= t.amount %>

            </td>


            <td class="flex gap-3">

              <%= link_to "Editar",
                          edit_transaction_path(t),
                          class:"text-blue-500 hover:text-blue-700" %>


              <%= button_to "Excluir",
                            transaction_path(t),
                            method: :delete,
                            data: { turbo:false, turbo_confirm:"Tem certeza?" },
                            class:"text-red-500 bg-transparent border-0 cursor-pointer" %>

            </td>

          </tr>

        <% end %>

        </tbody>

      </table>

    </div>

  </div>



  <!-- MODAL -->

  <div id="transactionModal"
       class="fixed inset-0 bg-black/30 hidden flex items-center justify-center">

    <div class="bg-white rounded-xl p-8 w-[400px]">

      <h3 class="text-xl font-semibold mb-6">
        Nova Transação
      </h3>

      <%= form_with model: Transaction.new,
                    url: transactions_path,
                    data:{ turbo:false } do |f| %>

        <div class="mb-4">

          <label>Descrição</label>

          <%= f.text_field :description,
                           class:"w-full p-2 border rounded-lg" %>

        </div>


        <div class="mb-4">

          <label>Valor</label>

          <%= f.number_field :amount,
                             step:0.01,
                             class:"w-full p-2 border rounded-lg" %>

        </div>


        <div class="mb-6">

          <label>Categoria</label>

          <%= f.select :category,
                       ["Receita","Despesa"],
                       {},
                       class:"w-full p-2 border rounded-lg" %>

        </div>


        <div class="flex justify-end gap-3">

          <button type="button"
                  onclick="closeModal()"
                  class="px-4 py-2 text-gray-600">
            Cancelar
          </button>


          <%= f.submit "Salvar",
                       class:"bg-green-500 text-white px-4 py-2 rounded-lg" %>

        </div>

      <% end %>

    </div>

  </div>



  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <script>

      document.addEventListener("DOMContentLoaded", function(){

          const labels = <%= raw @chart_labels.to_json %>
          const receitas = <%= raw @chart_receitas.to_json %>
          const despesas = <%= raw @chart_despesas.to_json %>

              new Chart(document.getElementById("financeChart"),{

                  type:"line",

                  data:{
                      labels:labels,

                      datasets:[

                          {
                              label:"Receitas",
                              data:receitas,
                              borderColor:"#22c55e",
                              backgroundColor:"rgba(34,197,94,0.2)",
                              fill:true
                          },

                          {
                              label:"Despesas",
                              data:despesas,
                              borderColor:"#ef4444",
                              backgroundColor:"rgba(239,68,68,0.2)",
                              fill:true
                          }

                      ]

                  }

              })


          new Chart(document.getElementById("categoryChart"),{

              type:"pie",

              data:{
                  labels:<%= raw @pizza_labels.to_json %>,

                  datasets:[{

                      data:<%= raw @pizza_values.to_json %>,

                      backgroundColor:[
                          "#ef4444",
                          "#22c55e",
                          "#3b82f6",
                          "#f59e0b"
                      ]

                  }]

              }

          })

      })


      function openModal(){
          document.getElementById("transactionModal").classList.remove("hidden")
      }

      function closeModal(){
          document.getElementById("transactionModal").classList.add("hidden")
      }

  </script>

</div>