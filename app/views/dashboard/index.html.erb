<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-100 font-[Poppins]">

  <!-- NAVBAR -->
  <nav class="flex justify-between items-center px-10 py-6">

    <h1 class="text-2xl font-semibold">
      💰 Pocket Control
    </h1>

    <%= link_to "Sair", root_path,
                class:"text-red-500 hover:text-red-600" %>

  </nav>


  <!-- CONTAINER -->
  <div class="max-w-6xl mx-auto px-6 mt-10">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-10">

      <h2 class="text-3xl font-bold">
        Seu Dashboard
      </h2>

      <button onclick="openModal()"
              class="bg-green-500 text-white px-5 py-2 rounded-lg hover:bg-green-600 shadow">
        Nova Transação
      </button>

    </div>


    <!-- CARDS -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">

      <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">

        <h3 class="text-gray-500 text-sm">
          Saldo Total
        </h3>

        <p class="text-3xl font-bold text-green-500">
          R$ <%= @saldo %>
        </p>

      </div>


      <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">

        <h3 class="text-gray-500 text-sm">
          Receitas
        </h3>

        <p class="text-3xl font-bold text-blue-500">
          R$ <%= @receitas %>
        </p>

      </div>


      <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">

        <h3 class="text-gray-500 text-sm">
          Despesas
        </h3>

        <p class="text-3xl font-bold text-red-500">
          R$ <%= @despesas %>
        </p>

      </div>

    </div>


    <!-- GRÁFICO -->
    <div class="bg-white rounded-xl shadow p-8 mb-12">

      <h3 class="text-xl font-semibold mb-6">
        Fluxo Financeiro
      </h3>

      <canvas id="financeChart"></canvas>

    </div>



    <!-- TRANSAÇÕES -->
    <div class="bg-white rounded-xl shadow p-8">

      <h3 class="text-xl font-semibold mb-6">
        Últimas Transações
      </h3>

      <table class="w-full">

        <thead>

        <tr class="text-left text-gray-500 border-b">

          <th class="py-3">Descrição</th>
          <th>Categoria</th>
          <th>Valor</th>

        </tr>

        </thead>

        <tbody>

        <% @transactions.each do |t| %>

          <tr class="border-b hover:bg-gray-50">

            <td class="py-3">
              <%= t.description %>
            </td>

            <td>
              <%= t.category %>
            </td>

            <td class="<%= t.category == 'Receita' ? 'text-green-500' : 'text-red-500' %> font-semibold">

              <%= t.category == "Receita" ? "+" : "-" %>
              R$ <%= t.amount %>

            </td>

          </tr>

        <% end %>

        </tbody>

      </table>

    </div>

  </div>



  <!-- MODAL -->
  <div id="transactionModal"
       class="fixed inset-0 bg-black bg-opacity-40 hidden
flex items-center justify-center">

    <div class="bg-white rounded-xl p-8 w-[400px] shadow-xl">

      <h3 class="text-xl font-semibold mb-6">
        Nova Transação
      </h3>

      <%= form_with model: Transaction.new do |f| %>

        <div class="mb-4">

          <label class="text-sm text-gray-600">
            Descrição
          </label>

          <%= f.text_field :description,
                           class:"w-full p-2 border rounded-lg" %>

        </div>

        <div class="mb-4">

          <label class="text-sm text-gray-600">
            Valor
          </label>

          <%= f.number_field :amount,
                             step: 0.01,
                             class:"w-full p-2 border rounded-lg" %>

        </div>

        <div class="mb-6">

          <label class="text-sm text-gray-600">
            Categoria
          </label>

          <%= f.select :category,
                       ["Receita","Despesa"],
                       {},
                       class:"w-full p-2 border rounded-lg" %>

        </div>

        <div class="flex justify-end gap-3">

          <button type="button"
                  onclick="closeModal()"
                  class="px-4 py-2 text-gray-600">
            Cancelar
          </button>

          <%= f.submit "Salvar",
                       class:"bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600" %>

        </div>

      <% end %>

    </div>

  </div>



  <!-- CHART -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <script>

      document.addEventListener("turbo:load", function(){

          const canvas = document.getElementById("financeChart");

          if(!canvas) return;

          const ctx = canvas.getContext("2d");

          new Chart(ctx,{

              type:"line",

              data:{

                  labels:<%= raw @chart_labels.to_json %>,

                  datasets:[

                      {
                          label:"Receitas",
                          data:<%= raw @chart_receitas.to_json %>,
                          borderColor:"#22c55e",
                          backgroundColor:"rgba(34,197,94,0.2)",
                          tension:0.4,
                          fill:true
                      },

                      {
                          label:"Despesas",
                          data:<%= raw @chart_despesas.to_json %>,
                          borderColor:"#ef4444",
                          backgroundColor:"rgba(239,68,68,0.2)",
                          tension:0.4,
                          fill:true
                      }

                  ]

              },

              options:{
                  responsive:true,
                  plugins:{
                      legend:{
                          position:"top"
                      }
                  }
              }

          });

      });

      function openModal(){
          document.getElementById("transactionModal").classList.remove("hidden")
      }

      function closeModal(){
          document.getElementById("transactionModal").classList.add("hidden")
      }

  </script>

</div>