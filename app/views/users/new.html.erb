<div class="flex items-center justify-center min-h-screen bg-gray-100">

  <div class="bg-white p-8 rounded-xl shadow-md w-96">

    <h1 class="text-2xl font-bold mb-6 text-center">Criar Conta</h1>

    <%= form_with model: @user do |f| %>

      <div class="mb-4">
        <%= f.label :name %>
        <%= f.text_field :name, class:"w-full border p-2 rounded" %>
      </div>

      <div class="mb-4">
        <%= f.label :email %>
        <%= f.email_field :email, class:"w-full border p-2 rounded" %>
      </div>

      <div class="mb-4">
        <%= f.label :password %>
        <%= f.password_field :password, class:"w-full border p-2 rounded" %>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, class:"w-full border p-2 rounded" %>
      </div>

      <%= f.submit "Cadastrar", class:"w-full bg-blue-500 text-white p-2 rounded" %>

    <% end %>

  </div>

</div>