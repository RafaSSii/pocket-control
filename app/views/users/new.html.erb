<div class="relative min-h-screen bg-gradient-to-br from-slate-50 to-blue-100 flex items-center justify-center font-[Poppins] overflow-hidden">

  <!-- BLOBS -->
  <div class="absolute -top-40 -left-40 w-[500px] h-[500px] bg-blue-300 rounded-full blur-[120px] opacity-30 blob-animate"></div>
  <div class="absolute bottom-[-150px] right-[-150px] w-[500px] h-[500px] bg-green-300 rounded-full blur-[120px] opacity-30 blob-animate-reverse"></div>

  <!-- VOLTAR -->
  <div class="absolute top-6 left-6">
    <%= link_to "← Voltar", root_path,
                class:"text-gray-700 hover:text-blue-500 text-lg" %>
  </div>

  <!-- CARD CADASTRO -->
  <div class="bg-gradient-to-br from-white/50 to-white/10
      backdrop-blur-xl border border-white/30
      shadow-xl p-10 rounded-2xl w-[420px] relative z-10">

    <h2 class="text-3xl font-bold mb-6 text-center">
      Criar Conta
    </h2>

    <%= form_with model: @user do |f| %>

      <div class="mb-4">
        <label class="block text-gray-700 mb-1">Nome</label>
        <%= f.text_field :name,
                         class:"w-full p-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-400" %>
      </div>

      <div class="mb-4">
        <label class="block text-gray-700 mb-1">Email</label>
        <%= f.email_field :email,
                          class:"w-full p-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-400" %>
      </div>

      <div class="mb-4">
        <label class="block text-gray-700 mb-1">Senha</label>
        <%= f.password_field :password,
                             class:"w-full p-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-400" %>
      </div>

      <div class="mb-6">
        <label class="block text-gray-700 mb-1">Confirmar Senha</label>
        <%= f.password_field :password_confirmation,
                             class:"w-full p-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-400" %>
      </div>

      <%= f.submit "Criar Conta",
                   class:"w-full bg-green-500 text-white py-3 rounded-lg hover:bg-green-600 transition" %>

    <% end %>

    <p class="text-center text-gray-600 mt-6">
      Já tem conta?
      <%= link_to "Entrar", login_path,
                  class:"text-blue-500 hover:underline" %>
    </p>

  </div>

</div>