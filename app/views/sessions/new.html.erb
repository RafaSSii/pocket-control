<div class="min-h-screen flex items-center justify-center bg-gray-50">

  <div class="absolute top-6 left-6">
    <%= link_to root_path,
                class:"flex items-center gap-2 text-gray-600 hover:text-black transition" do %>

      <span class="text-xl">←</span>
      <span class="text-sm font-medium">Voltar</span>

    <% end %>
  </div>

  <div class="w-full max-w-md bg-white p-10 rounded-2xl shadow-lg">

    <h1 class="text-2xl font-bold text-center mb-8">
      💰 Login 💰
    </h1>

    <%= form_with url: login_path, class:"space-y-5" do %>

      <div>
        <label class="block text-sm text-gray-600 mb-1">
          Email
        </label>

        <input
          type="email"
          name="email"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
        >
      </div>

      <div>
        <label class="block text-sm text-gray-600 mb-1">
          Senha
        </label>

        <input
          type="password"
          name="password"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
        >
      </div>

      <div class="flex items-center justify-between text-sm">

        <label class="flex items-center gap-2">
          <input type="checkbox" class="rounded">
          Lembrar de mim
        </label>

        <a href="#" class="text-blue-500 hover:underline">
          Esqueceu a senha?
        </a>

      </div>

      <button
        class="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600 transition"
      >
        Entrar
      </button>

    <% end %>

    <p class="text-center text-sm text-gray-500 mt-6">
      Não tem conta?
      <%= link_to "Criar conta", register_path, class:"text-blue-500 hover:underline" %>
    </p>

  </div>

</div>