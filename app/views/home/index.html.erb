<div class="relative min-h-screen bg-gradient-to-br from-slate-50 to-blue-100 font-[Poppins] flex flex-col overflow-hidden">


  <!-- BACKGROUND SHAPES -->
  <div class="absolute -top-40 -left-40 w-[500px] h-[500px] bg-blue-300 rounded-full blur-[120px] opacity-30 blob-animate"></div>

  <div class="absolute top-[300px] -right-40 w-[500px] h-[500px] bg-green-300 rounded-full blur-[120px] opacity-30 blob-animate-reverse"></div>


  <!-- NAVBAR -->
  <nav class="flex justify-between items-center px-10 py-6 relative z-10">

    <h1 class="text-2xl font-semibold">
      💰 Pocket Control
    </h1>

    <div class="space-x-4">
      <%= link_to "Entrar", login_path,
                  class:"text-gray-700 hover:text-blue-500" %>

      <%= link_to "Criar conta", register_path,
                  class:"bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600" %>
    </div>

  </nav>


  <!-- HERO -->
  <section class="text-center mt-20 px-6 relative z-10">

    <h2 class="text-5xl font-bold mb-6">
      Organize sua vida financeira
    </h2>

    <p class="text-gray-600 text-lg max-w-xl mx-auto mb-10">
      Controle suas despesas, visualize receitas e acompanhe
      sua evolução financeira através de dashboards inteligentes.
    </p>

  </section>


  <!-- FEATURES -->
  <section class="grid md:grid-cols-3 gap-8 mt-24 px-10 max-w-6xl mx-auto relative z-10">

    <div class="bg-gradient-to-br from-white/40 to-white/10
      backdrop-blur-xl
      border border-white/30
      shadow-lg shadow-black/5
      p-8 rounded-2xl
      transition-all duration-300
      hover:-translate-y-2 hover:shadow-2xl hover:from-white/50 hover:to-white/20">

      <h3 class="text-xl font-semibold mb-3">
        📊 Dashboards inteligentes
      </h3>

      <p class="text-gray-700">
        Visualize seus gastos e receitas em gráficos claros e organizados.
      </p>

    </div>


    <div class="bg-gradient-to-br from-white/40 to-white/10
      backdrop-blur-xl
      border border-white/30
      shadow-lg shadow-black/5
      p-8 rounded-2xl
      transition-all duration-300
      hover:-translate-y-2 hover:shadow-2xl hover:from-white/50 hover:to-white/20">

      <h3 class="text-xl font-semibold mb-3">
        💰 Controle de despesas
      </h3>

      <p class="text-gray-700">
        Registre todas suas despesas e categorize seus gastos.
      </p>

    </div>


    <div class="bg-gradient-to-br from-white/40 to-white/10
      backdrop-blur-xl
      border border-white/30
      shadow-lg shadow-black/5
      p-8 rounded-2xl
      transition-all duration-300
      hover:-translate-y-2 hover:shadow-2xl hover:from-white/50 hover:to-white/20">

      <h3 class="text-xl font-semibold mb-3">
        📈 Relatórios financeiros
      </h3>

      <p class="text-gray-700">
        Acompanhe sua evolução financeira ao longo do tempo.
      </p>

    </div>

  </section>


  <!-- GRÁFICO -->
  <section class="mt-28 px-6 relative z-10">

    <div class="max-w-5xl mx-auto text-center">

      <h2 class="text-3xl font-semibold mb-4">
        Acompanhe sua evolução financeira
      </h2>

      <p class="text-gray-600 mb-10">
        Visualize receitas e despesas em gráficos claros e intuitivos.
      </p>

    </div>

    <div class="bg-white/40 backdrop-blur-xl border border-white/20
                shadow-xl rounded-2xl p-10 max-w-4xl mx-auto">

      <canvas id="financeChart"></canvas>

    </div>

  </section>


  <!-- CTA -->
  <section class="mt-32 text-center px-6 relative z-10">

    <h2 class="text-3xl font-bold mb-6">
      Comece a organizar suas finanças hoje
    </h2>

    <p class="text-gray-600 mb-8">
      Crie sua conta gratuitamente e tenha controle total do seu dinheiro.
    </p>

    <%= link_to "Criar conta grátis", register_path,
                class:"bg-green-500 text-white px-8 py-3 rounded-lg text-lg hover:bg-green-600 shadow-lg" %>

  </section>


  <!-- FOOTER -->
  <footer class="mt-24 py-10 text-center text-gray-500 border-t border-gray-200 relative z-10">

    <p>© <%= Time.current.year %> Rafael Santos - Pocket Control</p>

  </footer>


  <!-- ANIMAÇÃO DOS BLOBS -->
  <style>

      @keyframes floatSlow {
          0% { transform: translate(0px,0px) scale(1); }
          50% { transform: translate(40px,-30px) scale(1.05); }
          100% { transform: translate(0px,0px) scale(1); }
      }

      @keyframes floatSlowReverse {
          0% { transform: translate(0px,0px) scale(1); }
          50% { transform: translate(-40px,30px) scale(1.05); }
          100% { transform: translate(0px,0px) scale(1); }
      }

      .blob-animate {
          animation: floatSlow 18s ease-in-out infinite;
      }

      .blob-animate-reverse {
          animation: floatSlowReverse 22s ease-in-out infinite;
      }

  </style>


  <!-- SCRIPT DO GRÁFICO -->
  <script>
      document.addEventListener("turbo:load", function () {

          const canvas = document.getElementById('financeChart');

          if (!canvas) return;

          const ctx = canvas.getContext('2d');

          new Chart(ctx, {
              type: 'line',
              data: {
                  labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun'],
                  datasets: [
                      {
                          label: 'Receitas',
                          data: [3000, 3200, 3500, 4200, 4500, 4800],
                          borderColor: '#22c55e',
                          backgroundColor: 'rgba(34,197,94,0.2)',
                          tension: 0.4,
                          fill: true
                      },
                      {
                          label: 'Despesas',
                          data: [2000, 2100, 2200, 2500, 2600, 2800],
                          borderColor: '#ef4444',
                          backgroundColor: 'rgba(239,68,68,0.2)',
                          tension: 0.4,
                          fill: true
                      }
                  ]
              },
              options: {
                  responsive: true,
                  plugins: {
                      legend: {
                          position: 'top'
                      }
                  }
              }
          });

      });
  </script>

</div>